{
  "manifest_version": 3,
  "name": "Drive2PDF",
  "version": "1.0.0",
  "description": "Capture rendered lazy-loaded document viewers and export the visible pages as a PDF.",
  "permissions": [
    "activeTab",
    "downloads",
    "offscreen",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://notesify.com/*",
    "https://*.notesify.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Drive2PDF",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  }
}
